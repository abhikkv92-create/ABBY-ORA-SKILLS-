{
  "version": "2.0.0",
  "description": "Abby ORA Intelligent Process Handlers - Workflow definitions and orchestration logic",
  "processes": {
    "intent_analysis": {
      "description": "Classify incoming query into domain and intent",
      "steps": [
        {
          "step": 1,
          "action": "extract_keywords",
          "description": "Identify Oracle module names, technical terms, action verbs"
        },
        {
          "step": 2,
          "action": "classify_domain",
          "description": "Determine primary domain (SCM/ERP/EPM/HCM/CX/Technical)"
        },
        {
          "step": 3,
          "action": "classify_intent",
          "description": "Determine query type (functional/technical/troubleshooting/planning/qa/research)"
        },
        {
          "step": 4,
          "action": "assess_complexity",
          "description": "Evaluate complexity (simple/medium/complex/expert)"
        },
        {
          "step": 5,
          "action": "determine_urgency",
          "description": "Assess urgency level (low/medium/high/critical)"
        }
      ]
    },
    "agent_routing": {
      "description": "Route query to appropriate specialist agents",
      "routing_rules": [
        {
          "condition": "domain=SCM AND intent=functional",
          "route_to": "scm-functional-consult"
        },
        {
          "condition": "domain=SCM AND intent=planning",
          "route_to": "scm-planning-expert"
        },
        {
          "condition": "intent=api OR intent=integration",
          "route_to": "api-integration-expert"
        },
        {
          "condition": "intent=troubleshooting OR intent=debugging",
          "route_to": "advanced-debugger"
        },
        {
          "condition": "intent=qa OR intent=testing",
          "route_to": "qa-uat-expert"
        },
        {
          "condition": "intent=planning OR intent=roadmap",
          "route_to": "pm-agent"
        },
        {
          "condition": "intent=research OR intent=trends",
          "route_to": "research-scholar"
        },
        {
          "condition": "domain=industry OR domain=vertical",
          "route_to": "industry-expert"
        },
        {
          "condition": "intent=workflow OR intent=process",
          "route_to": "workflow-orchestrator"
        },
        {
          "condition": "complexity=expert AND multiple_domains=true",
          "route_to": "orchestrate-task"
        }
      ]
    },
    "context_gathering": {
      "description": "Gather relevant Oracle knowledge and context",
      "sources": [
        "oracle_documentation",
        "mos_notes",
        "implementation_experience",
        "best_practices",
        "known_issues",
        "integration_points"
      ]
    },
    "response_synthesis": {
      "description": "Synthesize multi-agent outputs into coherent response",
      "output_structure": {
        "executive_summary": "Required",
        "detailed_analysis": "Required",
        "risk_assessment": "Required",
        "next_steps": "Required",
        "verification_steps": "Optional",
        "pro_tips": "Optional"
      },
      "quality_criteria": {
        "accuracy": "Oracle documentation correctness",
        "completeness": "All aspects covered",
        "actionability": "Clear next steps provided",
        "safety": "Production safety considerations"
      }
    },
    "quality_evaluation": {
      "description": "Evaluate response quality and track improvements",
      "metrics": [
        "accuracy_score",
        "completeness_score",
        "relevance_score",
        "actionability_score",
        "safety_score"
      ],
      "feedback_tracking": true
    }
  },
  "workflows": {
    "simple_query": {
      "description": "Single domain, straightforward query",
      "path": "intent_analysis → single_agent → response_synthesis → quality_evaluation"
    },
    "complex_query": {
      "description": "Multi-domain or expert-level query",
      "path": "intent_analysis → agent_routing → multi_agent_dispatch → context_gathering → response_synthesis → quality_evaluation"
    },
    "troubleshooting": {
      "description": "Error investigation and resolution",
      "path": "intent_analysis → advanced-debugger → context_gathering → root_cause_analysis → solution_synthesis → verification_steps"
    },
    "planning": {
      "description": "Implementation planning and roadmapping",
      "path": "intent_analysis → pm-agent → requirements_gathering → timeline_creation → resource_planning → risk_assessment"
    }
  }
}