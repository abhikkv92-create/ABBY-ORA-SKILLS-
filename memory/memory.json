{
  "version": "2.0.0",
  "description": "Abby ORA Intelligent Memory System - Session-based context tracking and learning",
  "memory_structure": {
    "session": {
      "id": "auto-generated",
      "created": "timestamp",
      "last_activity": "timestamp",
      "turn_count": 0
    },
    "context": {
      "current_domain": "scm|erp|epm|technical|functional|qa|research|pm|industry",
      "active_skill": "current_skill_name",
      "query_intent": "functional|technical|troubleshooting|planning|qa|research",
      "complexity": "simple|medium|complex|expert"
    },
    "conversation_history": {
      "queries": [],
      "responses": [],
      "actions_taken": []
    },
    "learned_patterns": {
      "user_preferences": {},
      "common_queries": [],
      "successful_responses": []
    }
  },
  "memory_tracking": {
    "track_intent": true,
    "track_domain": true,
    "track_actions": true,
    "track_outcomes": true,
    "track_quality_scores": true
  },
  "intelligent_features": {
    "intent_classification": {
      "enabled": true,
      "auto_detect": true,
      "domains": ["scm", "erp", "epm", "hcm", "cx", "technical", "functional", "qa", "research", "pm", "industry"]
    },
    "context_aware_routing": {
      "enabled": true,
      "route_to": ["scm-functional-consult", "scm-planning-expert", "api-integration-expert", "technical-architect", "advanced-debugger", "qa-uat-expert", "workflow-orchestrator", "industry-expert", "pm-agent", "research-scholar", "orchestrate-task"]
    },
    "pattern_recognition": {
      "enabled": true,
      "learn_from": ["queries", "responses", "feedback"]
    },
    "quality_tracking": {
      "enabled": true,
      "score_metrics": ["accuracy", "completeness", "relevance", "actionability"]
    }
  },
  "learning_modes": {
    "adaptive": {
      "description": "Learns from successful interactions and adjusts responses",
      "confidence_threshold": 0.7
    },
    "conservative": {
      "description": "Maintains core knowledge, only minor refinements",
      "confidence_threshold": 0.9
    },
    "strict": {
      "description": "No learning, always uses base knowledge",
      "confidence_threshold": 1.0
    }
  }
}